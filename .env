# ─────────────────────────────────────────────────────────────────────────────
# Hair Palace — Environment Template
# This file contains NO real secrets — only ${VAR} references.
# Real values live in .hairpalace (never committed).
#
# To generate the live env file:
#   source .hairpalace && envsubst < .env > .env.live
# Or simply run:  bash scripts/deploy.sh
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=${APP_ENV}
SECRET_KEY=${SECRET_KEY}
ALLOWED_ORIGINS=${ALLOWED_ORIGINS}

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=${POSTGRES_USER}
POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
POSTGRES_DB=${POSTGRES_DB}
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# ── Analytics DB ─────────────────────────────────────────────────────────────
ANALYTICS_DB_PASSWORD=${ANALYTICS_DB_PASSWORD}
ANALYTICS_DATABASE_URL=postgresql+asyncpg://analytics:${ANALYTICS_DB_PASSWORD}@analytics_db:5432/hairpalace_analytics

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Auth (JWT) ───────────────────────────────────────────────────────────────
JWT_SECRET=${JWT_SECRET}
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=${STRIPE_SECRET_KEY}
STRIPE_PUBLISHABLE_KEY=${STRIPE_PUBLISHABLE_KEY}
STRIPE_WEBHOOK_SECRET=${STRIPE_WEBHOOK_SECRET}

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=${SMTP_HOST}
SMTP_PORT=${SMTP_PORT}
SMTP_USE_SSL=${SMTP_USE_SSL}
SMTP_USER=${SMTP_USER}
SMTP_PASSWORD=${SMTP_PASSWORD}
EMAIL_FROM=${EMAIL_FROM}
ADMIN_EMAIL=${ADMIN_EMAIL}
FRONTEND_URL=${FRONTEND_URL}

# ── Test Database ─────────────────────────────────────────────────────────────
TEST_DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}_test

# ── Frontend (Next.js public vars) ───────────────────────────────────────────
NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=${STRIPE_PUBLISHABLE_KEY}
NEXT_PUBLIC_APP_NAME=Hair Palace

# ── AI Keys ───────────────────────────────────────────────────────────────────
GEMINI_API_KEY=${GEMINI_API_KEY}
DEEPSEEK_API_KEY=${DEEPSEEK_API_KEY}
GROQ_API_KEY=${GROQ_API_KEY}
MISTRAL_API_KEY=${MISTRAL_API_KEY}
OPENROUTER_API_KEY=${OPENROUTER_API_KEY}
CEREBRAS_API_KEY=${CEREBRAS_API_KEY}
SAMBANOVA_API_KEY=${SAMBANOVA_API_KEY}
GMAPS_API_KEY=${GMAPS_API_KEY}

# ── Kafka / Redpanda ─────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=redpanda:9092
