# ─────────────────────────────────────────────────────────────────────────────
# STRANDS — Environment Template
# Copy to .env and populate via:  source ~/.secrets && envsubst < .env.example > .env
# NEVER commit .env — only .env.example
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development               # development | staging | production
SECRET_KEY=${SECRET_KEY}          # 32-byte hex — openssl rand -hex 32
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=${POSTGRES_USER}
POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
POSTGRES_DB=strands
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/strands

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Auth (JWT) ───────────────────────────────────────────────────────────────
JWT_SECRET=${JWT_SECRET}          # 32-byte hex — openssl rand -hex 32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=${STRIPE_SECRET_KEY}
STRIPE_PUBLISHABLE_KEY=${STRIPE_PUBLISHABLE_KEY}
STRIPE_WEBHOOK_SECRET=${STRIPE_WEBHOOK_SECRET}

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=${SMTP_HOST}
SMTP_PORT=587
SMTP_USER=${SMTP_USER}
SMTP_PASSWORD=${SMTP_PASSWORD}
EMAIL_FROM=noreply@strands.co.za
ADMIN_EMAIL=${ADMIN_EMAIL}

# ── Test Database (Docker postgres — separate DB for test isolation) ────────────────────────────────────
TEST_DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/strands_test

# ── Frontend (Next.js public vars) ───────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=${STRIPE_PUBLISHABLE_KEY}
NEXT_PUBLIC_APP_NAME=STRANDS

# ── AI Keys (optional — for AI-powered features) ─────────────────────────────
GEMINI_API_KEY=${GEMINI_API_KEY}
DEEPSEEK_API_KEY=${DEEPSEEK_API_KEY}
GROQ_API_KEY=${GROQ_API_KEY}
MISTRAL_API_KEY=${MISTRAL_API_KEY}
OPENROUTER_API_KEY=${OPENROUTER_API_KEY}
CEREBRAS_API_KEY=${CEREBRAS_API_KEY}
SAMBANOVA_API_KEY=${SAMBANOVA_API_KEY}
GMAPS_API_KEY=${GMAPS_API_KEY}
